# Retell dashboard API key used only to verify tool-webhook signatures.
RETELL_API_KEY=replace-with-retell-api-key

# ngrok stable/reserved domain, without protocol, for example: carecloud.ngrok.app
NGROK_DOMAIN=replace-with-reserved-ngrok-domain
NGROK_AUTHTOKEN=replace-with-ngrok-authtoken

# Optional local logging level.
LOG_LEVEL=INFO
